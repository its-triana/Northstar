# Copy this file to `.env` and fill in the values. `.env` is git-ignored — never commit it.

# --- Phase 1 (required to actually write + notify) ---
# Supabase → Project Settings → API
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
# Discord → Server Settings → Integrations → Webhooks → New Webhook → Copy URL
DISCORD_WEBHOOK_URL=

# --- Phase 4 (Discord buttons / slash commands) ---
# Discord Developer Portal → your app → General Information / Bot
DISCORD_APPLICATION_ID=
DISCORD_PUBLIC_KEY=
DISCORD_BOT_TOKEN=
# Right-click your server icon → Copy Server ID (enable Developer Mode in
# Discord Settings → Advanced first). Guild-scoped commands register instantly.
DISCORD_GUILD_ID=
# Right-click each channel → Copy Channel ID
DISCORD_CHANNEL_DIGEST=
DISCORD_CHANNEL_PIPELINE=
DISCORD_CHANNEL_DISCOVERIES=
